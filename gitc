#!/usr/bin/php
<?php


	if (!isset($argv[1])) {
		help();
		exit(0);
	}

	$cmd = (string)$argv[1];
	if ($cmd === '') {
		help();
		exit(0);
	}
	if ($cmd[0] !== '-') {
		$cmd = '-' . $cmd;
	}


	$cma = [
		"-h" => [
			"aliases" => ["help", "h"],
			"title" => "ヘルプ",
			"fnc" => function() {
				help();
				return false;
			}
		],
		"-acp" => [
			"aliases" => ["cpa", "acp"],
			"title" => "追加→コミット→プッシュ (add/commit/push)",
			"notation" => "gitc -acp コミットコメント",
			"fnc" => function() {
				global $argv;
				if (!isset($argv[2])) {
					echo "Commit comment is required.\n"; return false; 
				}
				return true;
			},
			"coms" => function() {
				global $argv;
				return [
					"git add -A;",
					"git commit -m " . escapeshellarg($argv[2]) . ";",
					"git push;"
				];
			}
		],
		"-s" => [
			"title" => "状態表示",
			"notation" => "gitc -st",
			"coms" => [
				"git status;"
			]
		],
		"-st" => [
			"title" => "状態表示（短縮） (status -sb)",
			"notation" => "gitc -st",
			"coms" => [
				"git status -sb;"
			]
		],
		"-pl" => [
			"title" => "取り込み（rebase） (pull --rebase)",
			"notation" => "gitc -pl",
			"coms" => [
				"git pull --rebase;"
			]
		],
		"-ps" => [
			"title" => "送信 (push)",
			"notation" => "gitc -ps",
			"coms" => [
				"git push;"
			]
		],
		"-d" => [
			"title" => "差分表示 (diff)",
			"notation" => "gitc -d",
			"coms" => [
				"git diff;"
			]
		],
		"-ds" => [
			"title" => "差分表示（ステージ済み） (diff --staged)",
			"notation" => "gitc -ds",
			"coms" => [
				"git diff --staged;"
			]
		],
		"-lg" => [
			"title" => "履歴表示（グラフ） (log --graph)",
			"notation" => "gitc -lg",
			"coms" => [
				"git log --oneline --graph --decorate --all;"
			]
		],
		"-br" => [
			"title" => "ブランチ一覧 (branch)",
			"notation" => "gitc -br",
			"coms" => [
				"git branch;"
			]
		],
		"-sw" => [
			"title" => "ブランチ切り替え（作成しない） (switch)",
			"notation" => "gitc -sw <branch>",
			"fnc" => function() {
				global $argv;
				if (!isset($argv[2]) || $argv[2] === '') { echo "Branch name is required.\n"; return false; }
				$branch = $argv[2];
				if (!git_local_branch_exists($branch)) {
					echo "Branch does not exist: {$branch}\n";
					echo "If you want to create it: gitc -new {$branch}\n";
					return false;
				}
				return true;
			},
			"coms" => function() {
				global $argv;
				return [
					"git switch " . escapeshellarg($argv[2]) . ";"
				];
			},
			"help_coms" => [
				"git switch <branch>;"
			]
		],
		"-new" => [
			"title" => "新規ブランチ作成→切り替え (switch -c)",
			"notation" => "gitc -new <branch>",
			"fnc" => function() {
				global $argv;
				if (!isset($argv[2]) || $argv[2] === '') { echo "Branch name is required.\n"; return false; }
				$branch = $argv[2];
				if (git_local_branch_exists($branch)) {
					echo "Branch already exists: {$branch}\n";
					return false;
				}
				return true;
			},
			"coms" => function() {
				global $argv;
				return [
					"git switch -c " . escapeshellarg($argv[2]) . ";"
				];
			},
			"help_coms" => [
				"git switch -c <branch>;"
			]
		],
		"-ss" => [
			"title" => "一時退避（保存） (stash push)",
			"notation" => "gitc -ss [message]",
