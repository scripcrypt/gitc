				"git branch --merged;"
			]
		],
		"-status" => [
			"title" => "状態サマリー（ブランチ/最新コミット/差分） (summary)",
			"notation" => "gitc -status",
			"coms" => [
				"git branch --show-current;",
				"git log -1 --oneline --decorate;",
				"git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null;",
				"git rev-list --left-right --count @{upstream}...HEAD 2>/dev/null;",
				"git status -sb;"
			]
		],
		"-rs" => [
			"title" => "リセット（要確認） (reset)",
			"notation" => "gitc -rs <reset args...>",
			"fnc" => function() {
				global $argv;
				if (!isset($argv[2])) {
					echo "Reset args are required. Example: gitc -rs --soft HEAD~1\n";
					return false;
				}
				$argStr = implode(' ', array_slice($argv, 2));
				return confirm("Run: git reset {$argStr} ? [y/N]: ");
			},
			"coms" => function() {
				global $argv;
				$args = array_map('escapeshellarg', array_slice($argv, 2));
				return [
					"git reset " . implode(' ', $args) . ";"
				];
			},
			"help_coms" => [
