			"notation" => "gitc -rescue [HEAD@{n} | <hash>]",
			"fnc" => function() {
				global $argv;
				if (!isset($argv[2])) { return true; }
				$target = $argv[2];
				$branch = "rescue-" . date('Ymd-His');
				echo "Create branch {$branch} at {$target}\n";
				if (!confirm("OK? [y/N]: ")) {
					return false;
				}
				return true;
			},
			"coms" => function() {
				global $argv;
				if (!isset($argv[2])) {
					echo "Pick an entry from reflog and pass it as arg. Example: gitc -rescue HEAD@{5}\n\n";
					return [
						"git reflog -n 20 --date=iso;"
					];
				}
				$target = $argv[2];
				$branch = "rescue-" . date('Ymd-His');
				return [
					"git branch " . escapeshellarg($branch) . " " . escapeshellarg($target) . ";",
					"git switch " . escapeshellarg($branch) . ";"
				];
			},
			"help_coms" => [
				"git reflog -n 20;",
				"git branch rescue-YYYYmmdd-HHMMSS <target>;",
				"git switch rescue-YYYYmmdd-HHMMSS;"
			]
		],
	];

	$cma = expand_aliases($cma);




	if (isset($cma[$cmd])) {
		$com = $cma[$cmd];
		if (isset($com["fnc"])) {
			$fnc = $com["fnc"];
			if(!$fnc()) { exit; }
		}

		if (!isset($com["coms"])) {
			help();
			exit(1);
		}

		$coms = $com["coms"];
		if (is_callable($coms)) {
			$coms = $coms();
		}
		run_commands($coms);
		exit(0);
	}

	help();
	exit(1);




	function help() {
		global $cma;
		echo "git コマンド簡略化拡張コマンド\n\n";
		echo "引数      説明\n";
		echo "-----+--------------------------------\n";
		foreach ($cma as $c => $cm) {
			if (isset($cm["_is_alias"]) && $cm["_is_alias"]) {
				continue;
			}
			echo str_pad($c, 10, " ") . ($cm["title"] ?? "") . "\n";
			if (isset($cm["notation"])) {
				echo str_repeat(" ", 14) . $cm["notation"] . "\n";
			}
			$helpComs = null;
			if (isset($cm["help_coms"])) {
				$helpComs = $cm["help_coms"];
			} elseif (isset($cm["coms"]) && is_array($cm["coms"])) {
				$helpComs = $cm["coms"];
			}
			if (is_array($helpComs)) {
				for ($i = 0, $ci = count($helpComs); $i < $ci; $i++) {
					echo str_repeat(" ", 18) . $helpComs[$i] . "\n";
				}
			}
		}
	}

	function run_commands($coms) {
		if (!is_array($coms)) {
			echo "Internal error: coms must be array.\n";
			exit(1);
		}
		$ret = 0;
		foreach ($coms as $command) {
			$command = trim((string)$command);
			if ($command === '') {
				continue;
			}
			$command = normalize_git_color_command($command);
			echo "\$ " . $command . "\n";
			passthru($command, $ret);
			if ($ret !== 0) {
				exit($ret);
			}
		}
		echo "\n";
	}

	function normalize_git_color_command($command) {
		// If output is not a TTY (e.g. IDE output pane), git may disable colors.
		// Force colors for common git commands while keeping behavior for non-git commands.
		$trim = ltrim($command);
		if (!preg_match('/^git\s+/', $trim)) {
			return $command;
		}

		if (!preg_match('/\s--no-pager(\s|;|$)/', $command)) {
			$command = preg_replace('/^git\s+/', 'git --no-pager ', $command, 1);
		}
		if (!preg_match('/color\.ui=always/', $command) && !preg_match('/\s--color(=|\s)/', $command)) {
			$command = preg_replace('/^git\s+/', 'git -c color.ui=always ', $command, 1);
		}
		return $command;
	}

	function confirm($prompt) {
		fwrite(STDOUT, $prompt);
		$line = fgets(STDIN);
		if ($line === false) {
			return false;
		}
		$line = trim($line);
		return ($line === 'y' || $line === 'Y');
	}

	function expand_aliases($cma) {
		foreach ($cma as $key => $def) {
			if (!isset($def["aliases"]) || !is_array($def["aliases"])) {
				continue;
			}
			foreach ($def["aliases"] as $alias) {
				$alias = (string)$alias;
				$aliasDash = ($alias !== '' && $alias[0] === '-') ? $alias : '-' . $alias;
				if (isset($cma[$aliasDash])) {
					continue;
				}
				$cma[$aliasDash] = $def;
				$cma[$aliasDash]["_is_alias"] = true;
			}
		}
		return $cma;
	}

	function git_local_branch_exists($branch) {
		$branch = trim((string)$branch);
		if ($branch === '') {
			return false;
		}
		$ref = "refs/heads/" . $branch;
		$cmd = "git show-ref --verify --quiet " . escapeshellarg($ref);
		passthru($cmd, $ret);
		return $ret === 0;
	}

	function git_has_worktree_changes() {
		$out = [];
		$ret = 0;
		exec("git status --porcelain", $out, $ret);
		if ($ret !== 0) {
			return false;
		}
		return trim(implode("\n", $out)) !== '';
	}