		"-undo" => [
			"title" => "直前の操作を取り消す（要確認） (undo)",
			"notation" => "gitc -undo",
			"fnc" => function() {
				if (git_has_worktree_changes()) {
					if (!confirm("Discard ALL local changes (staged + unstaged)? [y/N]: ")) {
						return false;
					}
					run_commands([
						"git restore --staged .;",
						"git restore .;"
					]);
					return false;
				}

				if (!confirm("Undo last commit with soft reset (keep changes staged)? [y/N]: ")) {
					return false;
				}
				return true;
			},
			"coms" => [
